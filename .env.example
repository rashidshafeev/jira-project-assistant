# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in.  `.env` is gitignored — NEVER commit real secrets.
#
# Forge has no system keychain here, so the Forge CLI and the real-Jira test lane
# read credentials from these vars. The `npm run tunnel`, `npm run deploy`, and
# `npm run test:jira` scripts source this file for you; to run a raw `forge`/`forge
# tunnel` command yourself, load it first:  set -a; . ./.env; set +a
#
# This file is ONLY for the real-Jira / Forge paths. The mock preview and `npm test`
# need nothing here — the frontend's committed `frontend/.env.mock` covers them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Forge CLI — required for: npm run deploy, npm run tunnel, forge lint/install ──
# Create a token at https://id.atlassian.com/manage-profile/security/api-tokens
FORGE_EMAIL="you@example.com"
FORGE_API_TOKEN="your-atlassian-api-token"

# ── Real-Jira E2E lane — OPTIONAL (only for `npm run test:jira`) ─────────────────
# Setting JIRA_APP_URL is what ENABLES the opt-in `jira` Playwright lane; without it
# the suite stays mock-only. It's the Project Assistant *page* URL — open that page
# in Jira and copy the whole address bar. Shape (two UUIDs, no friendly suffix):
#   .../projects/<KEY>/apps/<app-id>/<route-id>
JIRA_APP_URL="https://your-site.atlassian.net/jira/software/projects/KEY/apps/APP_ID/ROUTE_ID"

# Credentials for the FIRST login (a DEDICATED test account — read from env only,
# never logged). Once a browser session is saved the lane reuses it, so these are
# used only when that session is missing/expired. Omit them to require a manually
# captured session instead. See docs/testing.md → "Real-Jira smoke".
JIRA_LOGIN="you@example.com"
JIRA_PASSWORD="your-test-account-password"

# Optional. Enables the interactive 2-step-code hand-off: if the account is
# challenged on login, the run pauses and reads the 6-char code you drop into this
# file (e.g.  echo ABC123 > e2e/.auth/otp.txt).
JIRA_OTP_FILE="e2e/.auth/otp.txt"

# Optional overrides (sensible defaults in code — uncomment to change):
#   JIRA_STORAGE    where the saved session is read/written (default e2e/.auth/jira.json)
#   JIRA_APP_FRAME  CSS selector for the app's Forge iframe (default covers CDN + tunnel)
# JIRA_STORAGE="e2e/.auth/jira.json"
# JIRA_APP_FRAME='iframe[title="Project Assistant"]'
