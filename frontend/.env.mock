# Loaded by `vite --mode mock` (npm run dev:mock) and the Docker `preview` service.
# Switches the API transport to the in-memory /mock instead of the Forge bridge.
VITE_USE_MOCKS=true

# Optional knob for the mock engine (see /mock/mock-db.ts): simulated latency so
# loading states are visible. Errors are injected deterministically via `?fault=…`
# / `window.__mock`, not a random rate — see docs/testing.md.
VITE_MOCK_LATENCY_MS=400
